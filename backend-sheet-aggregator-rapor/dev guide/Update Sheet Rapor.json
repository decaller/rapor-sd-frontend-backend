    {
      "parameters": {
        "jsCode": "/**\n * Converts the new, simpler data structure into a hierarchical tree.\n * The structure will be: Kelas > SubKelas.\n * All nodes are now clickable and include a fixed GID.\n * @param {Array} data The input data from the n8n node.\n * @returns {Array} The transformed tree data.\n */\nfunction convertNewDataToTree(data) {\n    const input = data[0].json;\n    const gsheetId = input.GsheetId;\n    const subClassList = input.data;\n    const fixedGid = 1676084899; // ✨ Your fixed GID\n\n    // Use an object to group subclasses by their main class number (1, 2, 3, etc.)\n    const classGroups = {};\n\n    // 1. Group all subclasses by their grade level\n    subClassList.forEach(subClass => {\n        const classNumber = subClass.SubKelas.charAt(0);\n\n        if (!classGroups[classNumber]) {\n            classGroups[classNumber] = [];\n        }\n\n        // Create the node for the specific subclass\n        const subClassNode = {\n            label: subClass.SubKelas,\n            value: JSON.stringify({\n                gsheetId: gsheetId,\n                gid: fixedGid, // ✨ GID added here\n                range: 'A' + subClass.BarisKe\n            })\n        };\n\n        classGroups[classNumber].push(subClassNode);\n    });\n\n    // 2. Convert the grouped object into the final array structure\n    const tree = [];\n    const sortedClassNumbers = Object.keys(classGroups).sort((a, b) => a - b);\n\n    for (const classNumber of sortedClassNumbers) {\n        const classNode = {\n            label: \"Kelas \" + classNumber,\n            value: JSON.stringify({\n                gsheetId: gsheetId,\n                gid: fixedGid // ✨ GID added here\n            }),\n            children: classGroups[classNumber]\n        };\n        tree.push(classNode);\n    }\n\n    return tree;\n}\n\n// In n8n, use the input from the previous node.\nconst inputData = items.map(item => ({ json: item.json }));\nreturn convertNewDataToTree(inputData);"
      },
