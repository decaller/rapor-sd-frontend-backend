    {
      "parameters": {
        "jsCode": "// Define the mapping from sheet name abbreviations to full subject names\nconst subjectMap = {\n    'PAI': 'Pendidikan Agama Islam',\n    'PP': 'Pendidikan Pancasila',\n    'BI': 'Bahasa Indonesia',\n    'MTK': 'Matematika',\n    'IPAS': 'Ilmu Pengetahuan Alam dan Sosial',\n    'PJOK': 'Pendidikan Jasmani Olahraga dan Kesehatan',\n    'SBY': 'Seni Budaya',\n    'BSU': 'Bahasa Sunda',\n    'BING': 'Bahasa Inggris',\n    'TIK': 'Teknologi Informasi dan Komunikasi',\n    'BAR': 'Bahasa Arab',\n    'FQH': 'Fikih',\n    'HDS': 'Hadis'\n};\n\n/**\n * Converts the input JSON data into a hierarchical tree structure.\n * @param {Array} data The input data from the n8n node.\n * @returns {Array} The transformed tree data.\n */\nfunction convertToTreeData(data) {\n    const tree = [];\n    const parsedData = data[0].json.data.reverse();\n\n    parsedData.forEach(classData => {\n        const gsheetId = classData.GsheetId;\n        const className = classData.Name;\n        const sheetIds = classData.SheetId;\n\n        if (!className || !sheetIds) {\n            return;\n        }\n\n        const classNode = {\n            label: className.replace(\"Nilai Mapel \", \"\"), // \"Nilai Mapel Kelas 6D\" -> \"Kelas 6D\"\n            children: []\n        };\n\n        const subjectChildren = [];\n        const rekapNode = { label: 'Rekapitulasi', children: [] };\n        const cetakNode = { label: 'Cetak Rapor', children: [] };\n        const coverNode = { label: 'Cover', children: [] };\n        const biodataNode = { label: 'Biodata', children: [] };\n\n        sheetIds.forEach(sheet => {\n            const fullSubjectName = subjectMap[sheet.NamaSheet];\n            const sheetNameLower = sheet.NamaSheet.toLowerCase(); // For case-insensitive matching\n\n            if (fullSubjectName) {\n                subjectChildren.push({\n                    label: fullSubjectName,\n                    value: JSON.stringify({ gsheetId, gid: sheet.SheetId })\n                });\n\n            } else if (sheetNameLower.startsWith('rekap')) {\n                rekapNode.children.push({\n                    label: 'Ledger '+sheet.NamaSheet.substring(6,100),\n                    value: JSON.stringify({ gsheetId, gid: sheet.SheetId })\n                });\n\n            } else if (sheetNameLower.startsWith('cetak')) {\n                cetakNode.children.push({\n                    label: sheet.NamaSheet,\n                    value: JSON.stringify({ gsheetId, gid: sheet.SheetId })\n                });\n                \n            } else if (sheetNameLower.startsWith('cover')) {\n                coverNode.children.push({\n                    label: sheet.NamaSheet,\n                    value: JSON.stringify({ gsheetId, gid: sheet.SheetId })\n                });\n\n            } else if (sheetNameLower.startsWith('biodata')) {\n                biodataNode.children.push({\n                    label: sheet.NamaSheet,\n                    value: JSON.stringify({ gsheetId, gid: sheet.SheetId })\n                });\n            }\n        });\n\n        // Add the categorized groups to the main class node\n        classNode.children.push(...subjectChildren);\n        \n        if (rekapNode.children.length > 0) {\n            classNode.children.push(rekapNode);\n        }\n        if (cetakNode.children.length > 0) {\n            classNode.children.push(cetakNode);\n        }\n        \n        // --- UPDATED: Cover and Biodata are now placed at the end ---\n        if (coverNode.children.length > 0) {\n            classNode.children.push(coverNode);\n        }\n        if (biodataNode.children.length > 0) {\n            classNode.children.push(biodataNode);\n        }\n\n        tree.push(classNode);\n    });\n\n    return tree;\n}\n\n// In n8n, use the input from the previous node.\nconst inputData = items.map(item => ({ json: item.json }));\nreturn convertToTreeData(inputData);"
      },
