# ══════════════════════════════════════════════════════════════════════════════
#  NOTE: This project is now part of a monorepo.
#  All environment variables are managed from the ROOT .env file.
#  See: ../.env.example
#
#  This file is kept for standalone local development only.
# ══════════════════════════════════════════════════════════════════════════════

# Application
PORT=3000

# SQLite database path (Docker: /app/database/database.sqlite)
DB_PATH=./database/database.sqlite

# API Security
# A secret key required in the x-api-key header for ALL /api/* requests.
# Generate a strong key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=replace_with_a_strong_random_secret_key

# Google Drive
# The ID of the root folder on Google Drive that contains all Tahun Ajaran subfolders.
ROOT_DRIVE_FOLDER=your_root_folder_id_here

# Google Service Account
# Place google-service-account.json in this folder, then set the path below
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json

# Google Drive Backup
# The ID of the master folder where daily backups will be stored.
BACKUP_DRIVE_FOLDER=your_master_backup_folder_id_here
