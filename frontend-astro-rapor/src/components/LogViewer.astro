---
// src/components/LogViewer.astro
---
<div 
  x-data="logViewerComponent()" 
  x-init="init()"
  class="bg-gray-900 rounded-lg shadow-lg p-6 max-w-4xl mx-auto text-gray-200 font-mono text-sm"
>
  <div class="flex justify-between items-center mb-4 border-b border-gray-700 pb-4">
    <h2 class="text-xl font-bold text-white flex items-center gap-2">
      <!-- Show spinner if syncing -->
      <span x-show="isSyncing" class="animate-spin h-3 w-3 bg-blue-500 rounded-full inline-block"></span>
      <span x-show="!isSyncing" class="h-3 w-3 bg-gray-500 rounded-full inline-block"></span>
      System Sync Logs
    </h2>
    <button 
      @click="triggerSync" 
      :disabled="isSyncing"
      class="bg-blue-600 hover:bg-blue-500 disabled:bg-gray-600 text-white px-4 py-2 rounded transition-colors"
      x-text="isSyncing ? 'Syncing...' : 'Force Sync'"
    ></button>
  </div>

  <!-- Log Container -->
  <div class="space-y-2 max-h-[600px] overflow-y-auto">
    <!-- Empty State -->
    <div x-show="logs.length === 0" class="text-gray-500 italic text-center py-10" style="display: none;">
      No recent sync logs found.
    </div>
    
    <!-- Loop through logs -->
    <template x-for="log in logs" :key="log.id">
      <div 
        class="p-3 rounded bg-gray-800 flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-4 border-l-4"
        :class="getBorderColor(log.status)"
      >
        <div class="text-gray-500 whitespace-nowrap">
          [<span x-text="formatTime(log.timestamp)"></span>]
        </div>
        
        <div class="flex-1">
          <strong class="text-gray-300" x-text="log.step_name"></strong>
          <p class="mt-1" :class="getTextColor(log.status)" x-text="log.message"></p>
        </div>

        <div 
          class="font-bold text-xs px-2 py-1 rounded bg-gray-900 uppercase tracking-wider" 
          :class="getTextColor(log.status)"
          x-text="log.status"
        ></div>
      </div>
    </template>
  </div>
</div>

<script is:inline>
  // Define the Alpine data component in global scope
  document.addEventListener('alpine:init', () => {
    Alpine.data('logViewerComponent', () => ({
      logs: [],
      pollingInterval: null,
      
      // Computed property using a getter
      get isSyncing() {
        return this.logs.length > 0 && this.logs[0].status === 'PENDING';
      },

      init() {
        this.fetchLogs();
        this.pollingInterval = setInterval(() => this.fetchLogs(), 2000);
      },

      destroy() {
        clearInterval(this.pollingInterval);
      },

      async fetchLogs() {
        try {
          const res = await fetch('/api/proxy-logs');
          if (res.ok) {
            this.logs = await res.json();
          }
        } catch (err) {
          console.error("Log fetch error:", err);
        }
      },

      async triggerSync() {
        if (!confirm("Are you sure you want to force a background sync?")) return;
        
        try {
           // Basic fetch proxy to trigger sync (Assuming you add this API proxy too later, or direct hit)
           // alert("Sync triggered!");
           // Optional: you can proxy to /api/rapor/sync using another file if needed
           alert("Sync triggered!");
        } catch(e) {
           console.error(e);
        }
      },

      // Styling and Formatting Helpers
      getBorderColor(status) {
        if (status === 'SUCCESS') return 'border-green-500';
        if (status === 'ERROR') return 'border-red-500';
        return 'border-yellow-500';
      },

      getTextColor(status) {
        if (status === 'SUCCESS') return 'text-green-400';
        if (status === 'ERROR') return 'text-red-400';
        return 'text-yellow-400';
      },

      formatTime(isoString) {
        if (!isoString) return '';
        const d = new Date(isoString);
        return d.toLocaleTimeString('id-ID', { hour12: false });
      }
    }));
  });
</script>
