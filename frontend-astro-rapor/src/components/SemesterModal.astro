---
// SemesterModal.astro
// Modal shown when multiple periods (semesters) are available to choose from
---

<!-- Modal Animation Styles -->
<style>
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.92) translateY(14px); }
    to   { opacity: 1; transform: scale(1)    translateY(0); }
  }
  .animate-modal-in { animation: modalIn 0.28s cubic-bezier(0.34,1.56,0.64,1) both; }
</style>

<div
  x-show="showSemesterModal"
  x-transition.opacity.duration.200ms
  class="fixed inset-0 z-50 flex items-center justify-center p-4"
  style="background:rgba(15,23,42,0.72);backdrop-filter:blur(5px);"
  style="display: none;"
>
  <div class="w-full max-w-md rounded-2xl bg-white shadow-2xl overflow-hidden animate-modal-in">

    <!-- Gradient header -->
    <div class="bg-gradient-to-br from-atlantis-800 via-atlantis-700 to-atlantis-500 px-6 pt-8 pb-7 text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-white/20 shadow-inner">
        <svg class="h-8 w-8 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
      </div>
      <h2 class="text-xl font-bold text-white tracking-tight">Selamat Datang di Rapor SD 🎓</h2>
      <p class="mt-1.5 text-sm text-atlantis-100/90">Silakan pilih Tahun Ajaran &amp; Semester untuk melanjutkan</p>
    </div>

    <!-- Period buttons -->
    <div class="px-6 py-5 space-y-3">
      <template x-for="(entry, index) in periodData" :key="index">
        <button
          @click="selectPeriod(entry)"
          class="period-btn group flex items-center gap-4 w-full rounded-xl border-2 border-gray-200 bg-white px-5 py-4 text-left transition-all duration-200 hover:border-atlantis-500 hover:bg-atlantis-50 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-atlantis-400"
        >
          <div class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full bg-atlantis-100 text-atlantis-700 group-hover:bg-atlantis-500 group-hover:text-white transition-colors duration-200">
            <!-- Icon for Semester Ganjil -->
            <svg x-show="entry.semester === 1" class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m8.66-9h-1M4.34 12h-1m15.07-6.07-.71.71M6.34 17.66l-.71.71m12.73 0-.71-.71M6.34 6.34l-.71-.71M12 7a5 5 0 100 10A5 5 0 0012 7z"/>
            </svg>
            <!-- Icon for Semester Genap -->
            <svg x-show="entry.semester !== 1" class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-gray-800 text-base" x-text="entry.tahunAjaran"></div>
            <div class="text-sm text-gray-500 group-hover:text-atlantis-700 transition-colors">
              <span x-text="entry.semester === 1 ? 'Semester Ganjil' : 'Semester Genap'"></span>
              &bull; Semester <span x-text="entry.semester"></span>
            </div>
          </div>
          <svg class="h-5 w-5 text-gray-300 group-hover:text-atlantis-500 transition-colors flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
          </svg>
        </button>
      </template>
    </div>

    <!-- Footer -->
    <div class="border-t border-gray-100 bg-gray-50 px-6 py-3 text-center">
      <p class="text-xs text-gray-400">SDI Insan Taqwa &bull; Sistem Rapor Digital</p>
    </div>
  </div>
</div>
