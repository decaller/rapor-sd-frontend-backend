---
// Navbar.astro
// Static shell — the #nav-container div is populated dynamically by client-side JS
---

<header id="main-header" class="bg-atlantis-900 shadow-lg z-20">
  <nav class="container mx-auto px-4">
    <div class="flex items-center justify-between w-full h-16">

      <!-- Logo + Dynamic Nav -->
      <div class="flex items-center h-full">
        <a href="#" class="text-xl font-bold text-white pr-4">Rapor SD</a>
        <div id="nav-container" class="flex items-center h-full" x-html="navHtml" @click.prevent="handleNavClick">
          <!-- Navigation is dynamically generated here by Alpine x-html -->
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex items-center space-x-2 pl-4">
        <button
          @click="refreshIframe"
          :disabled="!currentIframeUrl || isLoading"
          class="bg-atlantis-700 text-white p-2 rounded-md hover:bg-atlantis-600 disabled:bg-gray-500 disabled:cursor-not-allowed transition-colors duration-200"
          title="Refresh Frame"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h5m-5-2a9 9 0 112.55 12.08" />
          </svg>
        </button>

        <button
          @click="openNewTab"
          :disabled="!currentIframeUrl || isLoading"
          class="bg-atlantis-700 text-white p-2 rounded-md hover:bg-atlantis-600 disabled:bg-gray-500 disabled:cursor-not-allowed transition-colors duration-200"
          title="Open in New Tab"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </button>
      </div>

    </div>
  </nav>
</header>
