---
// RefreshToast.astro
// Appears 10s after iframe loads — prompts user to refresh if content is blank
---

<div
  x-show="showRefreshToast"
  x-transition.opacity.duration.300ms
  class="fixed bottom-5 right-5 bg-atlantis-900 text-white py-3 px-5 rounded-lg shadow-lg z-50"
  style="display: none;"
>
  <p>
    Tampilan kosong?
    <button @click.prevent="refreshIframe" class="underline hover:text-atlantis-300 ml-1">
      Refresh
    </button>
  </p>
</div>
