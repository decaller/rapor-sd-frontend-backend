---
// ContentArea.astro
// Shows a welcome/loading screen initially; iframe is revealed after a nav link is clicked
---

<main>
  <!-- Welcome / Loading State -->
  <div id="loader" class="flex flex-col items-center justify-center h-full bg-gray-100 text-gray-600 text-center p-4">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-12 w-12 text-gray-400 mb-4"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
      ></path>
    </svg>
    <p class="text-xl font-semibold">Selamat Datang!</p>
    <p class="text-md mt-2">Silakan pilih menu di atas untuk menampilkan data.</p>
  </div>

  <!-- Content iFrame (hidden until a menu item is clicked) -->
  <iframe id="content-frame" class="hidden" title="Rapor Content Viewer"></iframe>
</main>
