---
// BreadcrumbBar.astro
// Fixed bottom-left pill that shows the currently loaded content path after iframe loads
---

<div
  id="breadcrumb-bar"
  class="fixed bottom-5 left-5 bg-atlantis-800 text-white py-2 px-3 shadow-lg rounded-full z-40 hidden flex items-center justify-between transition-all duration-300"
>
  <span id="breadcrumb-text" class="text-sm truncate ml-2 mr-4">
    Path will be shown here...
  </span>

  <div class="flex items-center space-x-1 flex-shrink-0">
    <!-- Open in New Tab -->
    <button
      id="breadcrumb-new-tab-btn"
      class="p-2 rounded-full hover:bg-atlantis-700 transition-colors duration-200"
      title="Open in New Tab"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
      </svg>
    </button>

    <!-- Close Breadcrumb -->
    <button
      id="breadcrumb-close-btn"
      class="p-2 rounded-full hover:bg-atlantis-700 transition-colors duration-200"
      title="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</div>
