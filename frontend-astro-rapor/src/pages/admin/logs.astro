---
// src/pages/admin/logs.astro
import LogViewer from '../../components/LogViewer.astro';
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>System Logs | Rapor SD</title>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@latest/dist/full.min.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      let pwd = sessionStorage.getItem('app_password');
      if (!pwd) {
        pwd = prompt("Please enter the password to access the application:");
        if (pwd) {
          sessionStorage.setItem('app_password', pwd);
        } else {
          document.write('<div style="font-family: sans-serif; text-align: center; color: white; margin-top: 50px;">Access denied. Refresh to try again.</div>');
          window.stop();
        }
      }
    </script>
  </head>
  <body class="bg-base-300 min-h-screen">
    <div class="px-4 py-8">
      <!-- Mount the Alpine.js Component -->
      <LogViewer />
    </div>
  </body>
</html>
