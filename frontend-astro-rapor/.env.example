# ══════════════════════════════════════════════════════════════════════════════
#  NOTE: This project is now part of a monorepo.
#  All environment variables are managed from the ROOT .env file.
#  See: ../.env.example
#
#  This file is kept for standalone local development only.
#  PUBLIC_* variables are inlined at build time by Astro — they are
#  safe to expose in the browser.
# ══════════════════════════════════════════════════════════════════════════════

# Base URL for the backend API (accessed via Caddy in Docker)
# In production this will be the same domain (Caddy handles routing).
# For standalone local dev, point directly to the backend.
PUBLIC_API_BASE_URL=http://localhost:3000

# API key used when calling the backend from the browser (must match API_SECRET_KEY on backend)
PUBLIC_API_KEY=replace_with_the_same_key_as_backend_API_SECRET_KEY
