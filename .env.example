# ══════════════════════════════════════════════════════════════════════════════
#  RAPOR — Root Environment Variables
#  Copy this file to .env and fill in real values. Never commit .env!
#  Generate a secret key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ══════════════════════════════════════════════════════════════════════════════

# ── Caddy / Domain ───────────────────────────────────────────────────────────
# Set to your real domain in production (e.g. rapor.example.com).
# Use "localhost" for local HTTP-only development.
DOMAIN=localhost

# ── Backend ───────────────────────────────────────────────────────────────────
# Internal port the Express app listens on (Docker internal, not exposed publicly)
BACKEND_PORT=3000

# API Security — required in the x-api-key header for all /api/* requests
# Generate on Linux/macOS: openssl rand -hex 32
API_SECRET_KEY=replace_with_a_strong_random_secret_key

# Admin Password Hash — required in the x-admin-password header for frontend admin access
# Generate SHA256 hash on Linux/macOS: echo -n "your_password" | sha256sum | awk '{print $1}'
ADMIN_PASSWORD_HASH=replace_with_sha256_hash_of_your_password

# ── Google Drive ─────────────────────────────────────────────────────────────
# The ID of the root folder on Google Drive that contains all Tahun Ajaran subfolders.
# To find: open the folder in browser → copy the ID from the URL
# https://drive.google.com/drive/folders/<THIS_IS_THE_ID>
ROOT_DRIVE_FOLDER=your_root_folder_id_here

# Google Service Account — absolute path on the HOST machine
# SSH into your server, place the key in ~/secrets/, then set the full path here.
# Example: /home/youruser/secrets/google-service-account.json
GOOGLE_CREDENTIALS_PATH=/home/youruser/secrets/google-service-account.json

# ── Google Drive Backup ───────────────────────────────────────────────────────
# The ID of the master folder where daily backups will be stored.
BACKUP_DRIVE_FOLDER=your_master_backup_folder_id_here
